<script>
(function(){
  "use strict";

  // ---- Nav scroll state + mobile toggle ----
  var nav = document.getElementById('nav');
  var navLinks = document.getElementById('navLinks');
  var navToggle = document.getElementById('navToggle');
  var toggleOpen = false;

  window.addEventListener('scroll', function(){
    if(window.scrollY > 40){ nav.classList.add('scrolled'); }
    else{ nav.classList.remove('scrolled'); }
  }, {passive:true});

  navToggle.addEventListener('click', function(){
    toggleOpen = !toggleOpen;
    navLinks.classList.toggle('open', toggleOpen);
  });
  navLinks.querySelectorAll('a').forEach(function(a){
    a.addEventListener('click', function(){
      toggleOpen = false;
      navLinks.classList.remove('open');
    });
  });

  // ---- Scroll reveal ----
  var reveals = document.querySelectorAll('.reveal:not(.hero-text .reveal)');
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){
        entry.target.classList.add('in');
        io.unobserve(entry.target);
      }
    });
  }, {threshold:0.15, rootMargin:'0px 0px -60px 0px'});
  document.querySelectorAll('.section .reveal, .reveal-zoom').forEach(function(el){ io.observe(el); });

  // ---- Hero parallax (mouse + scroll) — statue only, text stays fixed ----
  var heroVisual = document.querySelector('.hero-visual-frame');
  var heroClouds = document.querySelector('.hero-clouds');
  var hero = document.getElementById('hero');
  var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if(!reduceMotion && heroVisual){
    hero.addEventListener('mousemove', function(e){
      var rect = hero.getBoundingClientRect();
      var x = (e.clientX - rect.left)/rect.width - 0.5;
      var y = (e.clientY - rect.top)/rect.height - 0.5;
      heroVisual.style.transform = 'translate(' + (x*10) + 'px,' + (y*8) + 'px)';
    }, {passive:true});

    window.addEventListener('scroll', function(){
      var sc = window.scrollY;
      if(sc < window.innerHeight && heroClouds){
        heroClouds.style.transform = 'translateY(' + (sc*0.15) + 'px)';
      }
    }, {passive:true});
  }

  // ---- Lightning flashes ----
  var lightning = document.getElementById('lightning');
  function flash(){
    if(reduceMotion) return;
    var seq = [0.5, 0, 0.28, 0, 0];
    var t = 0;
    seq.forEach(function(op, i){
      setTimeout(function(){ lightning.style.opacity = op; }, t);
      t += (i % 2 === 0) ? 70 : 90;
    });
  }
  function scheduleLightning(){
    var next = 7000 + Math.random()*12000;
    setTimeout(function(){ flash(); scheduleLightning(); }, next);
  }
  scheduleLightning();

  // ---- Floating gold motes ----
  var particleField = document.getElementById('particles');
  var count = window.innerWidth < 700 ? 16 : 30;
  for(var i=0;i<count;i++){
    var m = document.createElement('div');
    m.className = 'mote';
    var left = Math.random()*100;
    var dur = 14 + Math.random()*16;
    var delay = Math.random()*20;
    var drift = (Math.random()*60 - 30) + 'px';
    var size = (1.5 + Math.random()*2.5).toFixed(1) + 'px';
    m.style.left = left + 'vw';
    m.style.width = size;
    m.style.height = size;
    m.style.setProperty('--drift', drift);
    m.style.animationDuration = dur + 's';
    m.style.animationDelay = '-' + delay + 's';
    particleField.appendChild(m);
  }
})();
</script>
