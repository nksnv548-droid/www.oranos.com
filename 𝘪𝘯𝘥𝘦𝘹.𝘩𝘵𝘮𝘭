<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ORANOS — Strength is Earned. Legacy is Forged.</title>
<meta name="description" content="ORANOS is a Greek-inspired legacy of strength, mindset, and command. Membership cannot be bought — it is earned through the Titan Challenge.">
<link rel="icon" href="data:image/png;base64," type="image/png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700;800;900&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ============================================
   ORANOS — DESIGN TOKENS
   ============================================ */
:root{
  --bg: #050505;
  --bg-2: #0a0908;
  --bg-storm: #0b0e14;
  --marble: #F5F4EF;
  --marble-dim: #d9d7cf;
  --gold: #D4AF37;
  --gold-soft: #e8cd7a;
  --gold-dim: rgba(212,175,55,0.35);
  --gold-faint: rgba(212,175,55,0.1);
  --text: #FFFFFF;
  --secondary: #a19c8f;
  --line: rgba(212,175,55,0.18);
  --font-display: 'Cinzel', serif;
  --font-serif: 'Cormorant Garamond', serif;
  --font-sans: 'Poppins', sans-serif;
  --ease: cubic-bezier(.16,.84,.44,1);
}

*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg);
  color:var(--text);
  font-family:var(--font-sans);
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
img{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}
button{font-family:inherit;cursor:pointer;}
::selection{background:var(--gold);color:#000;}

@media (prefers-reduced-motion: reduce){
  *{animation-duration:0.01ms !important;animation-iteration-count:1 !important;transition-duration:0.01ms !important;scroll-behavior:auto !important;}
}

.eyebrow{
  font-family:var(--font-sans);
  font-size:0.7rem;
  letter-spacing:0.4em;
  text-transform:uppercase;
  color:var(--gold);
  font-weight:500;
  display:inline-block;
  margin-bottom:1.6rem;
}
.eyebrow::before{content:"— ";color:var(--gold-dim);}
.eyebrow::after{content:" —";color:var(--gold-dim);}

h1,h2,h3{
  font-family:var(--font-display);
  font-weight:700;
  letter-spacing:0.015em;
  line-height:1.14;
}
.section-title{
  font-size:clamp(2.1rem, 4.2vw, 3.6rem);
  color:var(--marble);
  text-align:center;
  margin-bottom:1.4rem;
  font-weight:600;
}
.lede{
  font-family:var(--font-serif);
  font-size:clamp(1.15rem, 2vw, 1.5rem);
  color:var(--secondary);
  font-style:italic;
  line-height:1.65;
  max-width:620px;
  margin:0 auto;
  text-align:center;
}
.container{
  max-width:1200px;
  margin:0 auto;
  padding:0 6vw;
}
.section{
  position:relative;
  padding:11rem 0;
}
.divider{
  width:1px;height:80px;
  background:linear-gradient(var(--gold-dim), transparent);
  margin:0 auto 2.6rem;
}
.divider.flip{background:linear-gradient(transparent, var(--gold-dim));}

/* decorative fluted column — pure CSS, used sparingly as architectural texture */
.column-motif{
  position:absolute;top:0;bottom:0;width:64px;
  background:
    repeating-linear-gradient(90deg,
      rgba(245,244,239,0.05) 0px, rgba(245,244,239,0.05) 2px,
      transparent 2px, transparent 11px);
  -webkit-mask-image:linear-gradient(180deg, transparent, rgba(0,0,0,0.7) 18%, rgba(0,0,0,0.7) 82%, transparent);
  mask-image:linear-gradient(180deg, transparent, rgba(0,0,0,0.7) 18%, rgba(0,0,0,0.7) 82%, transparent);
  opacity:0.5;
  pointer-events:none;
}
.column-motif.left{left:3vw;}
.column-motif.right{right:3vw;}
@media (max-width:900px){.column-motif{display:none;}}

/* reveal */
.reveal{opacity:0;transform:translateY(40px);transition:opacity 1.2s var(--ease), transform 1.2s var(--ease);}
.reveal.in{opacity:1;transform:translateY(0);}
.reveal-delay-1{transition-delay:.12s;}
.reveal-delay-2{transition-delay:.24s;}
.reveal-delay-3{transition-delay:.36s;}
.reveal-delay-4{transition-delay:.48s;}
.reveal-zoom{opacity:0;transform:scale(1.06);transition:opacity 1.3s var(--ease), transform 1.3s var(--ease);}
.reveal-zoom.in{opacity:1;transform:scale(1);}

/* ============================================
   ATMOSPHERE — storm / lightning / particles / fog
   ============================================ */
#lightning{
  position:fixed;inset:0;
  background:#fff;
  opacity:0;
  pointer-events:none;
  z-index:9998;
  mix-blend-mode:overlay;
}
#particles{
  position:fixed;inset:0;
  pointer-events:none;
  z-index:5;
  overflow:hidden;
}
.mote{
  position:absolute;
  bottom:-10px;
  width:3px;height:3px;
  border-radius:50%;
  background:var(--gold-soft);
  opacity:0.5;
  filter:blur(0.4px);
  animation:rise linear infinite;
}
@keyframes rise{
  0%{transform:translateY(0) translateX(0);opacity:0;}
  10%{opacity:0.55;}
  90%{opacity:0.3;}
  100%{transform:translateY(-110vh) translateX(var(--drift,20px));opacity:0;}
}
.grain{
  position:fixed;inset:0;z-index:6;pointer-events:none;
  background-image:radial-gradient(rgba(255,255,255,0.022) 1px, transparent 1px);
  background-size:3px 3px;
  opacity:0.5;
}
.vignette{
  position:fixed;inset:0;z-index:4;pointer-events:none;
  box-shadow:inset 0 0 18vw 4vw rgba(0,0,0,0.75);
}
.fog-layer{
  position:absolute;left:-10%;right:-10%;height:40%;
  pointer-events:none;
  background:linear-gradient(180deg, transparent, rgba(230,225,210,0.05) 40%, transparent);
  filter:blur(6px);
  opacity:0.6;
}

/* ============================================
   NAV
   ============================================ */
nav{
  position:fixed;top:0;left:0;right:0;
  z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.4rem 6vw;
  background:linear-gradient(rgba(5,5,5,0.85), transparent);
  backdrop-filter:blur(2px);
  transition:background .4s var(--ease), padding .4s var(--ease), border-color .4s var(--ease);
  border-bottom:1px solid transparent;
}
nav.scrolled{
  background:rgba(5,5,5,0.86);
  padding:0.9rem 6vw;
  border-bottom:1px solid var(--line);
}
.nav-logo{display:flex;align-items:center;gap:0.7rem;}
.nav-logo img{height:32px;width:auto;filter:drop-shadow(0 0 8px rgba(212,175,55,0.25));}
.nav-logo span{
  font-family:var(--font-display);
  letter-spacing:0.3em;
  font-size:0.92rem;
  color:var(--marble);
}
.nav-links{display:flex;gap:2.8rem;align-items:center;}
.nav-links a{
  font-size:0.76rem;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:var(--secondary);
  position:relative;
  transition:color .3s;
}
.nav-links a::after{
  content:"";position:absolute;left:0;bottom:-6px;width:0;height:1px;
  background:var(--gold);transition:width .3s var(--ease);
}
.nav-links a:hover{color:var(--marble);}
.nav-links a:hover::after{width:100%;}
.nav-cta{
  border:1px solid var(--gold-dim);
  padding:0.65rem 1.4rem;
  font-size:0.7rem;
  letter-spacing:0.12em;
  border-radius:2px;
  color:var(--gold-soft) !important;
}
.nav-cta:hover{background:var(--gold-faint);border-color:var(--gold);}
.nav-cta::after{display:none;}
.nav-toggle{display:none;flex-direction:column;gap:5px;background:none;border:none;z-index:1001;}
.nav-toggle span{width:24px;height:1.5px;background:var(--marble);transition:.3s;}

@media (max-width:860px){
  .nav-links{
    position:fixed;inset:0;
    background:rgba(5,5,5,0.98);
    flex-direction:column;justify-content:center;
    gap:2.3rem;
    transform:translateX(100%);
    transition:transform .5s var(--ease);
  }
  .nav-links.open{transform:translateX(0);}
  .nav-links a{font-size:1rem;}
  .nav-toggle{display:flex;}
}

/* ============================================
   HERO — statue beside text, never on top
   ============================================ */
#hero{
  position:relative;
  min-height:100vh;
  display:flex;align-items:center;
  overflow:hidden;
  padding:9rem 0 5rem;
}
.hero-atmos{
  position:absolute;inset:0;z-index:0;
  background:
    radial-gradient(ellipse 60% 45% at 78% 18%, rgba(232,205,122,0.14), transparent 60%),
    radial-gradient(ellipse 70% 55% at 15% 85%, rgba(20,18,14,0.5), transparent 60%),
    var(--bg);
}
.hero-clouds{
  position:absolute;inset:0;z-index:0;
  background:radial-gradient(ellipse 80% 50% at 15% -10%, rgba(11,14,20,0.55), transparent 60%),
             radial-gradient(ellipse 80% 50% at 90% 5%, rgba(11,14,20,0.5), transparent 55%);
  animation:drift 28s ease-in-out infinite alternate;
}
@keyframes drift{
  0%{transform:translateX(-3%) translateY(0);}
  100%{transform:translateX(3%) translateY(1.5%);}
}
.hero-fog{top:60%;}
.hero-grid{
  position:relative;z-index:2;
  width:100%;
  display:grid;
  grid-template-columns:1.05fr 0.95fr;
  align-items:center;
  gap:4vw;
}
.hero-text{max-width:620px;}
.hero-title{
  font-size:clamp(2.4rem, 5vw, 4.4rem);
  color:var(--marble);
  text-shadow:0 4px 40px rgba(0,0,0,0.5);
  line-height:1.1;
}
.hero-title .line2{
  display:block;
  margin-top:0.15em;
  background:linear-gradient(120deg, var(--gold-soft), var(--gold) 45%, var(--gold-soft));
  -webkit-background-clip:text;background-clip:text;color:transparent;
}
.hero-sub{
  font-family:var(--font-serif);
  font-style:italic;
  font-size:clamp(1.15rem, 2vw, 1.5rem);
  color:var(--secondary);
  margin:1.8rem 0 2.8rem;
  line-height:1.5;
}
.hero-actions{display:flex;gap:1.2rem;flex-wrap:wrap;}

.hero-visual{
  position:relative;
  display:flex;
  justify-content:center;
  align-items:center;
  height:100%;
}
.hero-visual-frame{
  position:relative;
  width:min(100%, 420px);
  aspect-ratio:3/4;
  border-radius:4px;
  overflow:hidden;
  will-change:transform;
  animation:float-slow 8s ease-in-out infinite;
}
.hero-visual-frame img{
  width:100%;height:100%;object-fit:cover;object-position:center 20%;
  filter:contrast(1.06) brightness(0.98);
}
.hero-visual-frame::after{
  content:"";position:absolute;inset:0;
  background:linear-gradient(180deg, transparent 55%, rgba(5,5,5,0.55));
}
.hero-visual-frame::before{
  content:"";position:absolute;inset:-1px;
  border:1px solid var(--gold-dim);
  border-radius:4px;
  z-index:3;
  pointer-events:none;
}
.hero-visual-glow{
  position:absolute;
  width:120%;height:120%;
  background:radial-gradient(ellipse at center, rgba(212,175,55,0.16), transparent 65%);
  filter:blur(10px);
  z-index:-1;
}
@keyframes float-slow{
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-14px);}
}

@media (max-width:900px){
  .hero-grid{grid-template-columns:1fr;text-align:center;}
  .hero-text{max-width:100%;margin:0 auto;}
  .hero-actions{justify-content:center;}
  .hero-visual{margin-top:3rem;}
  .hero-visual-frame{width:min(78vw, 340px);}
}

.scroll-cue{
  position:absolute;bottom:2.6rem;left:50%;transform:translateX(-50%);
  z-index:3;
  display:flex;flex-direction:column;align-items:center;gap:0.6rem;
  color:var(--secondary);font-size:0.64rem;letter-spacing:0.32em;text-transform:uppercase;
  animation:bob 2.4s ease-in-out infinite;
}
.scroll-cue .stem{width:1px;height:36px;background:linear-gradient(var(--gold), transparent);}
@keyframes bob{0%,100%{transform:translate(-50%,0);}50%{transform:translate(-50%,8px);}}

/* ============================================
   ABOUT
   ============================================ */
#about{background:linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);}
.about-inner{max-width:800px;margin:0 auto;text-align:center;}
.about-body{
  font-family:var(--font-serif);
  font-size:clamp(1.25rem, 2.2vw, 1.65rem);
  line-height:1.8;
  color:var(--marble-dim);
  margin-top:1.8rem;
}
.about-body strong{color:var(--gold-soft);font-weight:600;}

/* ============================================
   PILLARS
   ============================================ */
#pillars{background:var(--bg-2);}
.pillar-grid{
  display:grid;
  grid-template-columns:repeat(4, 1fr);
  gap:1px;
  background:var(--line);
  margin-top:4.5rem;
  border:1px solid var(--line);
}
.pillar-card{
  background:var(--bg);
  padding:2.8rem 1.8rem 2.6rem;
  text-align:center;
  position:relative;
  transition:background .4s;
}
.pillar-card:hover{background:#0d0c0a;}
.pillar-num{
  font-family:var(--font-display);
  font-size:0.7rem;
  color:var(--gold-dim);
  letter-spacing:0.22em;
  margin-bottom:1.3rem;
  display:block;
}
.pillar-frame{
  width:150px;height:190px;
  margin:0 auto 1.7rem;
  overflow:hidden;
  border-radius:2px;
  position:relative;
  border:1px solid var(--line);
}
.pillar-frame img{
  width:100%;height:100%;object-fit:cover;object-position:center 12%;
  filter:grayscale(0.12) contrast(1.05);
  transition:transform .6s var(--ease);
}
.pillar-card:hover .pillar-frame img{transform:scale(1.06);}
.pillar-frame::after{
  content:"";position:absolute;inset:0;
  background:linear-gradient(180deg, transparent 62%, rgba(0,0,0,0.5));
}
.pillar-card h3{
  font-size:1.15rem;color:var(--marble);letter-spacing:0.06em;margin-bottom:0.9rem;
}
.pillar-card p{
  font-size:0.88rem;color:var(--secondary);line-height:1.7;
}
@media (max-width:920px){
  .pillar-grid{grid-template-columns:repeat(2,1fr);}
}
@media (max-width:520px){
  .pillar-grid{grid-template-columns:1fr;}
}

/* ============================================
   BENEFITS
   ============================================ */
#benefits{background:var(--bg);}
.benefits-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:1.5rem 3.6rem;
  max-width:820px;margin:4.5rem auto 0;
}
.benefit-item{
  display:flex;align-items:flex-start;gap:1rem;
  padding:1.15rem 0;
  border-bottom:1px solid rgba(255,255,255,0.06);
}
.benefit-mark{
  color:var(--gold);font-family:var(--font-display);font-size:0.95rem;flex-shrink:0;margin-top:0.15rem;
}
.benefit-item span.txt{
  font-size:1rem;color:var(--marble-dim);letter-spacing:0.01em;
}
@media (max-width:700px){.benefits-grid{grid-template-columns:1fr;gap:0;}}

/* ============================================
   TITAN CHALLENGE — full-screen cinematic, one statue
   ============================================ */
#titan{
  position:relative;
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
  padding:8rem 0;
  isolation:isolate;
}
.titan-bg{
  position:absolute;inset:0;z-index:0;
  background-image:url('data:image/jpeg;base64,');
  background-size:cover;
  background-position:center 15%;
  filter:brightness(0.4) contrast(1.1) saturate(0.85);
  transform:scale(1.1);
}
.titan-scrim{
  position:absolute;inset:0;z-index:1;
  background:
    radial-gradient(ellipse 65% 55% at 50% 40%, rgba(5,5,5,0.35), rgba(5,5,5,0.88) 78%),
    linear-gradient(180deg, rgba(5,5,5,0.75) 0%, rgba(5,5,5,0.35) 30%, rgba(5,5,5,0.35) 70%, var(--bg) 100%);
}
.titan-rays{
  position:absolute;inset:0;z-index:1;
  background:radial-gradient(ellipse 50% 40% at 50% 8%, rgba(232,205,122,0.16), transparent 60%);
}
.titan-content{
  position:relative;z-index:2;
  text-align:center;
  max-width:720px;
  margin:0 auto;
  padding:0 6vw;
}
.titan-statement{
  font-family:var(--font-serif);
  font-style:italic;
  font-size:clamp(1.4rem,2.8vw,1.9rem);
  color:var(--gold-soft);
  margin:1.4rem 0 1.8rem;
  line-height:1.4;
}
.titan-content p.desc{
  font-size:1.02rem;color:var(--secondary);line-height:1.85;margin:0 auto 2.6rem;max-width:520px;
}

/* ============================================
   JOURNEY (timeline — real sequence, numbers earned)
   ============================================ */
#journey{background:var(--bg);}
.timeline{
  max-width:720px;margin:4.8rem auto 0;
  position:relative;
}
.timeline::before{
  content:"";position:absolute;left:24px;top:6px;bottom:6px;width:1px;
  background:linear-gradient(var(--gold-dim), var(--gold-dim) 90%, transparent);
}
@media (max-width:600px){.timeline::before{left:18px;}}
.t-step{
  display:flex;gap:1.9rem;align-items:flex-start;
  padding:1.7rem 0;
  position:relative;
}
.t-num{
  width:50px;height:50px;flex-shrink:0;
  border-radius:50%;
  border:1px solid var(--gold-dim);
  background:var(--bg-2);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-display);color:var(--gold);font-size:1rem;
  position:relative;z-index:2;
}
@media (max-width:600px){.t-num{width:38px;height:38px;font-size:0.85rem;}}
.t-body h3{font-size:1.15rem;color:var(--marble);margin-bottom:0.35rem;letter-spacing:0.03em;}
.t-body p{font-size:0.92rem;color:var(--secondary);}
.t-step.final .t-num{background:linear-gradient(120deg, var(--gold-soft), var(--gold));color:#000;border-color:var(--gold);}
.t-step.final .t-body h3{color:var(--gold-soft);}

/* ============================================
   COMMUNITY — minimal, text-forward
   ============================================ */
#community{
  background:var(--bg-2);
  position:relative;
  overflow:hidden;
  text-align:center;
}
#community .container{max-width:680px;}
#community .section-title{margin-bottom:1.2rem;}
#community p.desc{
  font-size:1.05rem;color:var(--secondary);line-height:1.85;margin:0 auto 2.6rem;max-width:520px;
}

/* ============================================
   FINAL CTA
   ============================================ */
#final{
  min-height:80vh;
  display:flex;align-items:center;justify-content:center;
  text-align:center;
  position:relative;
  background:
    radial-gradient(ellipse 60% 50% at 50% 30%, rgba(212,175,55,0.08), transparent 70%),
    var(--bg);
  border-top:1px solid var(--line);
}
.final-quote{
  font-family:var(--font-serif);
  font-style:italic;
  font-size:clamp(1.8rem, 4vw, 3rem);
  color:var(--marble);
  max-width:800px;
  margin:1.8rem auto 2.8rem;
  line-height:1.4;
}
.final-quote .accent{color:var(--gold-soft);}

/* signature seal */
.seal{
  --size:132px;
  width:var(--size);height:var(--size);
  position:relative;
  margin:0 auto 2.4rem;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
}
.seal-ring{
  position:absolute;inset:0;border-radius:50%;
  background:conic-gradient(from 0deg, var(--gold) 0deg, transparent 40deg, transparent 320deg, var(--gold) 360deg);
  animation:spin 14s linear infinite;
  -webkit-mask:radial-gradient(farthest-side, transparent calc(100% - 2px), #000 calc(100% - 2px));
  mask:radial-gradient(farthest-side, transparent calc(100% - 2px), #000 calc(100% - 2px));
}
.seal-core{
  width:78%;height:78%;border-radius:50%;
  background:radial-gradient(circle at 35% 30%, #171410, #050505 70%);
  border:1px solid var(--gold-dim);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 30px rgba(212,175,55,0.18), inset 0 0 18px rgba(212,175,55,0.12);
}
.seal-core img{width:52%;height:auto;filter:drop-shadow(0 0 6px rgba(212,175,55,0.4));}
@keyframes spin{to{transform:rotate(360deg);}}

/* generic buttons */
.btn{
  display:inline-flex;align-items:center;gap:0.6rem;
  padding:1.1rem 2.5rem;
  font-size:0.76rem;
  letter-spacing:0.18em;
  text-transform:uppercase;
  font-weight:600;
  border-radius:2px;
  position:relative;
  overflow:hidden;
  transition:transform .35s var(--ease), box-shadow .35s var(--ease);
}
.btn-primary{
  background:linear-gradient(120deg, var(--gold-soft), var(--gold));
  color:#0a0a0a;
}
.btn-primary:hover{
  transform:translateY(-2px);
  box-shadow:0 10px 40px rgba(212,175,55,0.35);
}
.btn-primary::after{
  content:"";position:absolute;inset:0;
  background:linear-gradient(120deg, transparent, rgba(255,255,255,0.5), transparent);
  transform:translateX(-120%) skewX(-15deg);
  transition:transform .7s;
}
